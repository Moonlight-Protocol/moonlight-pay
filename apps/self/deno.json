{
  "name": "@moonlight-protocol/moonlight-pay-self",
  "version": "0.1.1",
  "license": "MIT",
  "tasks": {
    "dev": "deno run --allow-all --watch src/server.ts",
    "build": "deno run --allow-all src/build.ts",
    "serve": "deno run --allow-all src/server.ts",
    "test": "deno test --allow-all src/"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.ns", "dom", "dom.iterable"]
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.0.0",
    "@creit.tech/stellar-wallets-kit": "npm:@creit.tech/stellar-wallets-kit@^1.4.0",
    "stellar-base": "npm:@stellar/stellar-base@14.1.0",
    "stellar-sdk": "npm:@stellar/stellar-sdk@14.2.0",
    "@noble/curves/p256": "jsr:@noble/curves@^1.8.0/p256",
    "@noble/curves/abstract/modular": "jsr:@noble/curves@^1.8.0/abstract/modular",
    "@noble/hashes/sha256": "jsr:@noble/hashes@^1.6.1/sha256",
    "@noble/hashes/hkdf": "jsr:@noble/hashes@^1.6.1/hkdf",
    "buffer": "npm:buffer@^6.0.3",
    "shared/": "../../shared/src/"
  }
}
